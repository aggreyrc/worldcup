# ─── App ─────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-this-in-production
DEBUG=true

# ─── Sports Data Provider ────────────────────────────────
FOOTBALL_PROVIDER=sofascore

# SofaScore via RapidAPI
# 1. Go to https://rapidapi.com/apidojo/api/sofascore
# 2. Subscribe to the API
# 3. Copy your key from the "Header Parameters" section (x-rapidapi-key)
SOFASCORE_KEY=

# API-Football via RapidAPI — works from any IP including Docker
# 1. Go to https://rapidapi.com/api-sports/api/api-football
# 2. Click Subscribe → choose Basic (FREE — 100 req/day, 10 req/min)
# 3. Copy your key from the "Header Parameters" section (x-rapidapi-key)
APIFOOTBALL_KEY=b927400559mshc213b68ae4541c0p1e40a3jsnbb93eace9fc3

APIFOOTBALL_USE_RAPIDAPI=true

# SportAPI via RapidAPI — use SPORTS API provider for live scores and fixtures
# 1. Go to https://rapidapi.com/search/sportapi
# 2. Subscribe to SportAPI / SportAPI7
# 3. Set your RapidAPI key below
SPORTAPI_KEY=
SPORTAPI7_KEY=

# SportMonks (alternative — free plan lacks livescores endpoint)
SPORTMONKS_KEY=

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://livescore:livescore@localhost:5433/livescore
POSTGRES_DB=livescore
POSTGRES_USER=livescore
POSTGRES_PASSWORD=livescore

# ─── Redis / Celery ──────────────────────────────────────
# Docker publishes Redis to 6380 by default to avoid conflicts with a local
# Redis process on 6379. Set REDIS_HOST_PORT=6379 if you need the old mapping.
REDIS_HOST_PORT=6380
# Overridden inside Docker by docker-compose.yml
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Cache TTLs (seconds) ────────────────────────────────
CACHE_LIVE_SCORES_TTL=15
CACHE_FIXTURES_TTL=300
CACHE_STANDINGS_TTL=300
CACHE_MATCH_DETAIL_TTL=20
CACHE_LINEUPS_TTL=600

# ─── Frontend ────────────────────────────────────────────
# LEAVE EMPTY FOR LOCAL DEV — Vite proxy handles routing to Flask
# Only set this in production pointing at your deployed server
VITE_API_BASE_URL=

VITE_ADSENSE_PUBLISHER_ID=
VITE_GA_MEASUREMENT_ID=

# ─── Monetisation ────────────────────────────────────────
ADSENSE_PUBLISHER_ID=
GAM_NETWORK_CODE=
# Google AdSense
# Use your publisher client ID and ad unit slot IDs from AdSense.
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_DEFAULT_SLOT=1234567890
VITE_ADSENSE_HEADER_BANNER_SLOT=1234567890
VITE_ADSENSE_IN_FEED_SLOT=1234567890
VITE_ADSENSE_SIDEBAR_TOP_SLOT=1234567890
VITE_ADSENSE_SIDEBAR_STICKY_SLOT=1234567890
VITE_ADSENSE_IN_ARTICLE_SLOT=1234567890
VITE_ADSENSE_MOBILE_FOOTER_SLOT=1234567890
